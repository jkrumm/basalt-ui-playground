# Committable non-secret defaults.
# Override with .env.local for local secrets (gitignored).

# Ports
WEB_PORT=7712
API_PORT=7713

# Local URLs
WEB_URL=http://basalt-ui-playground.local:7712
API_URL=http://basalt-ui-playground-api.local:7713

# OpenTelemetry (HyperDX ClickStack self-hosted — no auth needed)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=basalt-ui-playground-api

# HyperDX browser RUM (self-hosted doesn't validate API key)
VITE_HYPERDX_API_KEY=dev
VITE_HYPERDX_SERVICE_NAME=basalt-ui-playground-web
# Self-hosted ClickStack UI/collector endpoint (browser SDK uses this as `url`)
VITE_HYPERDX_ENDPOINT=http://localhost:8080

# Umami Analytics (leave empty to disable in development)
VITE_UMAMI_SCRIPT_URL=
VITE_UMAMI_WEBSITE_ID=
