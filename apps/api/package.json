{
  "name": "@cbbi/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "dev": "node --env-file=.env.local --watch --experimental-strip-types src/index.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:setup": "drizzle-kit migrate",
    "db:generate": "pnpm dlx @better-auth/cli generate --config src/auth.ts --output src/schema/auth-schema.ts",
    "db:seed": "node --env-file=.env.local --experimental-strip-types src/seed.ts"
  },
  "dependencies": {
    "@cbbi/schemas": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.4",
    "@scalar/hono-api-reference": "^0.10.5",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "postgres": "^3.4.8",
    "stoker": "^2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
