# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Required: Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# Required in production: Base URL for auth callbacks
BETTER_AUTH_URL=http://localhost:3000

# CORS allowed origin (defaults to BETTER_AUTH_URL value)
ALLOWED_ORIGIN=http://localhost:3000

# API server port (default: 3001)
PORT=3001
