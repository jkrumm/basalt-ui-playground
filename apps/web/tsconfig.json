{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "resolveJsonModule": true,
    "paths": {
      "~/*": ["./src/*"],
      "content-collections": ["./.content-collections/generated"]
    }
  },
  "include": [
    "src",
    "server.ts",
    "vite.config.ts",
    "content-collections.ts",
    "src/content/**/*.mdx"
  ]
}
