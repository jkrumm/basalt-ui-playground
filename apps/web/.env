# Non-secret web defaults. Override with .env.local for secrets (gitignored).
PORT=7712
VITE_HYPERDX_API_KEY=5e19c139-f2dc-4555-97fc-1a797aae4da3
VITE_HYPERDX_SERVICE_NAME=basalt-ui-playground-web
# Browser SDK sends to /v1/logs + /v1/traces — proxied through web server to avoid CORS
VITE_HYPERDX_ENDPOINT=
# SSR OpenTelemetry — same collector + key as API
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=authorization=5e19c139-f2dc-4555-97fc-1a797aae4da3
# Leave empty to disable Umami in development
VITE_UMAMI_SCRIPT_URL=
VITE_UMAMI_WEBSITE_ID=
