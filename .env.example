# Full reference for all environment variables.
# Copy to .env.local and fill in real values (gitignored).
# Non-secret defaults live in .env (committed).

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cbbi:cbbi@localhost:5432/cbbi

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=<generate-32-char-random-secret>
BETTER_AUTH_URL=http://basalt-ui-playground-api.local:7713

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=7713
# Allowed CORS origin (web app URL)
ALLOWED_ORIGIN=http://basalt-ui-playground.local:7712

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=7712
VITE_API_URL=http://basalt-ui-playground-api.local:7713

# ── OpenTelemetry (HyperDX ClickStack self-hosted) ────────────────────────────
# Dev: app running on host
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Prod: app running in Docker on monitoring-net
# OTEL_EXPORTER_OTLP_ENDPOINT=http://clickstack:4318
OTEL_SERVICE_NAME=basalt-ui-playground-api

# ── HyperDX Browser RUM ───────────────────────────────────────────────────────
# Self-hosted ClickStack does not validate API keys — any non-empty string works
VITE_HYPERDX_API_KEY=dev
VITE_HYPERDX_SERVICE_NAME=basalt-ui-playground-web
# Self-hosted ClickStack UI/collector endpoint for browser SDK (defaults to HyperDX cloud if unset)
VITE_HYPERDX_ENDPOINT=http://localhost:8080

# ── Umami Analytics ───────────────────────────────────────────────────────────
# Leave empty to disable tracking (e.g. in development)
# Self-hosted:  VITE_UMAMI_SCRIPT_URL=https://<your-umami-host>/script.js
# Cloud:        VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
VITE_UMAMI_SCRIPT_URL=
VITE_UMAMI_WEBSITE_ID=
