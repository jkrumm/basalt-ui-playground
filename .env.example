# Full reference for environment variables.
#
# Non-secret defaults are committed in:
#   apps/api/.env  — API server defaults
#   apps/web/.env  — Web app defaults (VITE_* vars)
#
# Secrets go in apps/api/.env (gitignored for local dev).

# ── Database ──────────────────────────────────────────────────────────────────
# VPS: user=basalt_ui_playground, schema=basalt_ui_playground, shared main DB
DATABASE_URL=postgresql://basalt_ui_playground:<password>@localhost:5432/<main-db>

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=<generate-32-char-random-secret>
BETTER_AUTH_URL=http://basalt-ui-playground-api.local:7713/api/auth

# ── API ───────────────────────────────────────────────────────────────────────
PORT=7713
# Allowed CORS origin (web app URL)
ALLOWED_ORIGIN=http://basalt-ui-playground.local:7712

# ── OpenTelemetry (HyperDX ClickStack self-hosted) ────────────────────────────
# Dev: app running on host (VPS dev.compose.yml maps 4318:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Docker: app running in compose network
# OTEL_EXPORTER_OTLP_ENDPOINT=http://clickstack:4318
OTEL_SERVICE_NAME=basalt-ui-playground-api

# ── Web ───────────────────────────────────────────────────────────────────────
PORT=7712

# ── HyperDX Browser RUM ───────────────────────────────────────────────────────
# Self-hosted ClickStack does not validate API keys — any non-empty string works
VITE_HYPERDX_API_KEY=dev
VITE_HYPERDX_SERVICE_NAME=basalt-ui-playground-web
# VPS dev.compose.yml maps 7707:8080 — browser SDK sends data to this port
VITE_HYPERDX_ENDPOINT=http://localhost:7707

# ── Umami Analytics ───────────────────────────────────────────────────────────
# Leave empty to disable tracking (e.g. in development)
VITE_UMAMI_SCRIPT_URL=
VITE_UMAMI_WEBSITE_ID=
