# pnpm configuration for this monorepo

# Prevent dependency hoisting — each package resolves its own deps
shamefully-hoist=false

# Automatically install peer dependencies
auto-install-peers=true

# Don't fail on unresolvable peer dep conflicts (handled via peerDependencyRules)
strict-peer-dependencies=false

# Resolve peers from workspace root (pnpm 10 — improves peer resolution in monorepos)
resolve-peers-from-workspace-root=true
