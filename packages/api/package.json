{
  "name": "@cbbi/api",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:setup": "drizzle-kit push",
    "db:generate": "bunx @better-auth/cli generate --config src/auth.ts --output src/schema/auth-schema.ts"
  },
  "dependencies": {
    "@cbbi/schemas": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "typescript": "6.0.1-rc"
  }
}
