    "db:generate": "vp run api#db:generate",
    "db:seed": "vp run api#db:seed"
  },
  "devDependencies": {
    "@blueprintjs/eslint-plugin": "^6.1.24",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "oxlint-plugin-eslint": "^1.57.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
