{
  "name": "basalt-ui-playground",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter 'web' dev & bun run --filter 'api' dev",
    "dev:web": "bun run --filter 'web' dev",
    "dev:api": "bun run --filter 'api' dev",
    "build": "bun run --filter '*' build",
    "start": "bun run --filter 'web' start",
    "typecheck": "bun run --filter '*' typecheck",
    "fmt": "oxfmt --check packages/ apps/ *.json *.toml *.md",
    "fmt:fix": "oxfmt packages/ apps/ *.json *.toml *.md",
    "lint": "oxlint packages/ apps/ --deny-warnings",
    "check": "bun run fmt && bun run lint && bun run typecheck",
    "db:setup": "psql -h localhost -U postgres -f scripts/setup-cbbi-db.sql",
    "db:generate": "bun run --filter 'api' db:generate",
    "db:migrate": "bun run --filter 'api' db:migrate",
    "db:seed": "bun run --filter 'api' db:seed",
    "db:studio": "bun run --filter 'api' db:studio"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
