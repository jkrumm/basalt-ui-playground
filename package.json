{
  "name": "basalt-ui-playground",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter 'web' dev & bun run --filter 'api' dev",
    "dev:web": "bun run --filter 'web' dev",
    "dev:api": "bun run --filter 'api' dev",
    "build": "bun run --filter '*' build",
    "start": "bun run --filter '*' start",
    "typecheck": "bun run --filter '*' typecheck",
    "fmt": "oxfmt --check packages/ apps/ *.json *.toml *.md",
    "fmt:fix": "oxfmt packages/ apps/ *.json *.toml *.md",
    "lint": "oxlint packages/ apps/ --max-warnings 0 && eslint .",
    "lint:style": "stylelint 'apps/**/*.css'",
    "check": "bun run fmt && bun run lint && bun run lint:style && bun run typecheck",
    "db:generate": "bun run --filter 'api' db:generate",
    "db:migrate": "bun run --filter 'api' db:migrate",
    "db:seed": "bun run --filter 'api' db:seed",
    "db:studio": "bun run --filter 'api' db:studio"
  },
  "devDependencies": {
    "@blueprintjs/eslint-plugin": "^6.1.24",
    "@eslint/js": "^10.0.1",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "^1.58.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
