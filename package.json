{
  "name": "basalt-ui-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run web#dev",
    "dev:api": "vp run api#dev",
    "dev:web": "vp run web#dev",
    "build": "vp run web#build",
    "start": "vp run web#start",
    "typecheck": "vp run typecheck -r",
    "ready": "vp fmt && vp lint && vp run typecheck -r && vp run build -r",
    "prepare": "vp config",
